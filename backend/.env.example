# Server
PORT=3000
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/unified_personnel

# Redis (defaults to redis://localhost:6379 if omitted)
REDIS_URL=redis://localhost:6379

# RSA key pair for JWT signing (RS256)
# Generate with:
#   mkdir -p keys
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
PUBLIC_KEY_PATH=./keys/public.pem
PRIVATE_KEY_PATH=./keys/private.pem

# SMTP (used for password-reset OTP emails)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-user
EMAIL_PASS=your-smtp-password
EMAIL_FROM="Unified Personnel System <noreply@example.com>"
